{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["templates/nextjs-dashboard/*"]
    }
  },
  "include": [
    "typescript/**/*.ts",
    "templates/nextjs-dashboard/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
